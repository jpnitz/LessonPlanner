NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Server-only — required to create additional student logins (Phase 2+)
# Find in Supabase Dashboard → Project Settings → API → secret key
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# Server-only — default OpenAI key for /api/chat when a student has no key saved
# If .env.local is read-only in the editor, edit via terminal: nano .env.local
OPENAI_API_KEY=sk-your-openai-key-here

# Optional overrides for the LLM provider
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
